# ============================================================
# 环境变量示例
# 复制此文件为 .env.development 并填入真实值
# ============================================================

# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://<user>@localhost:5432/<dbname>
DATABASE_URL_SYNC=postgresql://<user>@localhost:5432/<dbname>

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- JWT ---
JWT_SECRET=<generate-a-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# --- 微信小程序 ---
WECHAT_APPID=<your-miniapp-appid>
WECHAT_SECRET=<your-miniapp-secret>

# --- 微信支付 ---
WECHAT_PAY_MCHID=<your-merchant-id>
WECHAT_PAY_API_KEY=<your-api-key>
WECHAT_PAY_APPID=<your-miniapp-appid>
WECHAT_PAY_NOTIFY_URL=https://<your-domain>/api/payment/callback

# --- ???? ---
CHAT_BACKEND=disabled
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=<your-dify-api-key>

# --- 应用配置 ---
APP_NAME=weMiniApp
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# --- 文件存储 ---
UPLOAD_DIR=./uploads
STORAGE_TYPE=local
